{% extends 'base.html.twig' %}

{% block title %}
    {{ 'skills.page_title'|trans }} | My Portfolio
{% endblock %}

{% block body %}

<section
    class="skills-page"
    aria-labelledby="skills-title"
    aria-describedby="skills-intro"
>

    <div class="skills-container">

        <header class="skills-header">

            <h1 id="skills-title">
                {{ 'skills.title'|trans }}
            </h1>

            <p id="skills-intro">
                {{ 'skills.intro'|trans }}
            </p>

        </header>

        <div class="skills-grid">

            <article
                class="skills-card"
                aria-labelledby="frontend-title"
            >

                <h2 id="frontend-title">
                    {{ 'skills.categories.frontend'|trans }}
                </h2>

                <ul
                    class="skills-list"
                    aria-label="{{ 'skills.categories.frontend'|trans }}"
                >

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/html5.png') }}"
                            alt="HTML"
                        >
                        <span>HTML</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/css3.png') }}"
                            alt="CSS"
                        >
                        <span>CSS</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/javascript.svg') }}"
                            alt="JavaScript"
                        >
                        <span>JavaScript</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/react-native-1.svg') }}"
                            alt="React"
                        >
                        <span>React</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/tailwind-css.svg') }}"
                            alt="Tailwind CSS"
                        >
                        <span>Tailwind CSS</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/bootstrap-5-1.svg') }}"
                            alt="Bootstrap"
                        >
                        <span>Bootstrap</span>
                    </li>

                </ul>

            </article>

            <article
                class="skills-card"
                aria-labelledby="backend-title"
            >

                <h2 id="backend-title">
                    {{ 'skills.categories.backend'|trans }}
                </h2>

                <ul
                    class="skills-list"
                    aria-label="{{ 'skills.categories.backend'|trans }}"
                >

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/php-6.svg') }}"
                            alt="PHP"
                        >
                        <span>PHP</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/symfony.svg') }}"
                            alt="Symfony"
                        >
                        <span>Symfony</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/doctrine-orm.png') }}"
                            alt="Doctrine ORM"
                        >
                        <span>Doctrine</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/nodejs.svg') }}"
                            alt="Node.js"
                        >
                        <span>Node.js</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/expressjs.png') }}"
                            alt="Express"
                        >
                        <span>Express</span>
                    </li>

                </ul>

            </article>

            <article
                class="skills-card"
                aria-labelledby="database-title"
            >

                <h2 id="database-title">
                    {{ 'skills.categories.database'|trans }}
                </h2>

                <ul
                    class="skills-list"
                    aria-label="{{ 'skills.categories.database'|trans }}"
                >

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/mysql-3.svg') }}"
                            alt="MySQL"
                        >
                        <span>MySQL</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/mongodb-icon-1.svg') }}"
                            alt="MongoDB"
                        >
                        <span>MongoDB</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/heidiSQL.jpg') }}"
                            alt="HeidiSQL"
                        >
                        <span>HeidiSQL</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/docker-3.svg') }}"
                            alt="Docker"
                        >
                        <span>Docker</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/laragon.svg') }}"
                            alt="Laragon"
                        >
                        <span>Laragon</span>
                    </li>

                </ul>

            </article>

            <article
                class="skills-card"
                aria-labelledby="tools-title"
            >

                <h2 id="tools-title">
                    {{ 'skills.categories.tools'|trans }}
                </h2>

                <ul
                    class="skills-list"
                    aria-label="{{ 'skills.categories.tools'|trans }}"
                >

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/git.svg') }}"
                            alt="Git"
                        >
                        <span>Git</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/github-icon-2.svg') }}"
                            alt="GitHub"
                        >
                        <span>GitHub</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/visual-studio-code-1.svg') }}"
                            alt="Visual Studio Code"
                        >
                        <span>VS Code</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/figma-icon.svg') }}"
                            alt="Figma"
                        >
                        <span>Figma</span>
                    </li>

                    <li class="skill-item">
                        <img
                            src="{{ asset('images/icones/trello.svg') }}"
                            alt="Trello"
                        >
                        <span>Trello</span>
                    </li>

                </ul>

            </article>

        </div>

    </div>

</section>

{% endblock %}