{% extends 'base.html.twig' %}

{% block title %}
    {{ 'contact.page_title'|trans }} | My Portfolio
{% endblock %}

{% block body %}

<section class="contact-page">

    <div class="contact-container">

        <header class="contact-header">

            <h1>{{ 'contact.title'|trans }}</h1>

            <p>
                {{ 'contact.intro'|trans }}
            </p>

        </header>

        {{ form_start(contact_form, {
            attr: {
                class: 'contact-form'
            }
        }) }}

            <div class="contact-grid">

                <div class="contact-column">

                    {{ form_row(contact_form.lastName) }}

                    {{ form_row(contact_form.firstName) }}

                    {{ form_row(contact_form.email) }}

                    {{ form_row(contact_form.subject) }}

                </div>

                <div class="contact-column">

                    {{ form_row(contact_form.message) }}

                </div>

            </div>

            <div class="contact-honeypot" aria-hidden="true">

                {{ form_widget(contact_form.website) }}

                {{ form_errors(contact_form.website) }}

            </div>

            <div class="contact-footer">

                <div class="contact-privacy">

                    <div class="contact-privacy-field">

                        {{ form_widget(contact_form.privacy) }}

                        <label for="{{ contact_form.privacy.vars.id }}">

                            {{ 'contact.form.privacy_start'|trans }}

                            <a
                                href="#"
                                class="contact-privacy-link"
                                data-privacy-modal-open
                            >
                                {{ 'contact.form.privacy_link'|trans }}
                            </a>.

                        </label>

                        {{ form_errors(contact_form.privacy) }}

                    </div>

                </div>

                <div class="contact-submit">

                    {{ form_row(contact_form.submit) }}

                </div>

            </div>

        {{ form_end(contact_form) }}

    </div>

</section>

<div
    class="privacy-modal"
    data-privacy-modal
    aria-hidden="true"
>
    <div
        class="privacy-modal-overlay"
        data-privacy-modal-close
    ></div>

    <div
        class="privacy-modal-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="privacy-modal-title"
    >

        <button
            type="button"
            class="privacy-modal-close"
            data-privacy-modal-close
            aria-label="{{ 'contact.modal.close'|trans }}"
        >
            ×
        </button>

        <h2 id="privacy-modal-title">
            {{ 'rgpd.title'|trans }}
        </h2>

        <div class="privacy-modal-content">

            <section>
                <h3>{{ 'rgpd.controller.title'|trans }}</h3>
                <p>{{ 'rgpd.controller.text'|trans }}</p>
            </section>

            <section>
                <h3>{{ 'rgpd.data.title'|trans }}</h3>
                <p>{{ 'rgpd.data.text'|trans }}</p>
            </section>

            <section>
                <h3>{{ 'rgpd.use.title'|trans }}</h3>
                <p>{{ 'rgpd.use.text'|trans }}</p>
            </section>

            <section>
                <h3>{{ 'rgpd.storage.title'|trans }}</h3>
                <p>{{ 'rgpd.storage.text'|trans }}</p>
            </section>

            <section>
                <h3>{{ 'rgpd.sharing.title'|trans }}</h3>
                <p>{{ 'rgpd.sharing.text'|trans }}</p>
            </section>

            <section>
                <h3>{{ 'rgpd.rights.title'|trans }}</h3>
                <p>{{ 'rgpd.rights.text'|trans }}</p>
            </section>

            <section>
                <h3>{{ 'rgpd.cookies.title'|trans }}</h3>
                <p>{{ 'rgpd.cookies.text'|trans }}</p>
            </section>

        </div>

        <button
            type="button"
            class="privacy-modal-button"
            data-privacy-modal-close
        >
            {{ 'contact.modal.close_button'|trans }}
        </button>

    </div>

</div>

{% endblock %}