<header class="site-header">

    <nav
        class="navbar"
        aria-label="Navigation principale"
    >

        <a
            href="{{ path('app_home', {
                '_locale': app.request.locale
            }) }}"
            class="navbar-logo"
            aria-label="Retour à l’accueil"
        >
            <img
                src="{{ asset('images/logos/logo_myPortFolio.svg') }}"
                alt=""
                aria-hidden="true"
            >
        </a>

        <input
            type="checkbox"
            id="menu-toggle"
            class="menu-toggle"
            aria-hidden="true"
            tabindex="-1"
        >

        <label
            for="menu-toggle"
            class="hamburger"
            aria-label="Ouvrir ou fermer le menu principal"
        >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </label>

        <ul
            class="navbar-menu"
            id="navbar-menu"
        >

            <li>
                <a
                    href="{{ path('app_home', {
                        '_locale': app.request.locale
                    }) }}"
                >
                    {{ 'navbar.home'|trans }}
                </a>
            </li>

            <li>
                <a
                    href="{{ path('app_skills', {
                        '_locale': app.request.locale
                    }) }}"
                >
                    {{ 'navbar.skills'|trans }}
                </a>
            </li>

            <li>
                <a
                    href="{{ path('app_projects', {
                        '_locale': app.request.locale
                    }) }}"
                >
                    {{ 'navbar.projects'|trans }}
                </a>
            </li>

            <li>
                <a
                    href="{{ path('app_contact', {
                        '_locale': app.request.locale
                    }) }}"
                >
                    {{ 'navbar.contact'|trans }}
                </a>
            </li>

            <li>
                <a
                    href="{{ path('app_cv', {
                        '_locale': app.request.locale
                    }) }}"
                >
                    {{ 'navbar.cv'|trans }}
                </a>
            </li>

            {% if is_granted('ROLE_ADMIN') %}

                <li class="mobile-admin-dashboard">
                    <a href="{{ path('admin') }}">
                        {{ 'navbar.admin'|trans }}
                    </a>
                </li>

                <li class="mobile-logout">
                    <a href="{{ path('app_logout') }}">
                        {{ 'navbar.logout'|trans }}
                    </a>
                </li>

            {% else %}

                <li class="mobile-login">
                    <a href="{{ path('app_login') }}">
                        {{ 'navbar.login'|trans }}
                    </a>
                </li>

            {% endif %}

            <li class="mobile-github">
                <a
                    href="https://github.com/jefflearning40"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Ouvrir le profil GitHub dans un nouvel onglet"
                >
                    GitHub
                </a>
            </li>

        </ul>

        <nav
            class="navbar-language"
            aria-label="Choix de la langue"
        >

            <a
                href="{{ path(
                    app.request.attributes.get('_route'),
                    app.request.attributes.get('_route_params')|merge({
                        '_locale': 'fr'
                    })
                ) }}"
                lang="fr"
                hreflang="fr"
                {% if app.request.locale == 'fr' %}
                    aria-current="page"
                {% endif %}
            >
                FR
            </a>

            <span aria-hidden="true">|</span>

            <a
                href="{{ path(
                    app.request.attributes.get('_route'),
                    app.request.attributes.get('_route_params')|merge({
                        '_locale': 'en'
                    })
                ) }}"
                lang="en"
                hreflang="en"
                {% if app.request.locale == 'en' %}
                    aria-current="page"
                {% endif %}
            >
                EN
            </a>

        </nav>

        {% if is_granted('ROLE_ADMIN') %}

            <a
                href="{{ path('app_logout') }}"
                class="
                    navbar-admin-status
                    navbar-admin-status--connected
                "
                aria-label="{{ 'navbar.logout_aria'|trans }}"
                title="{{ 'navbar.logout'|trans }}"
            >
                <img
                    src="{{ asset('images/icones/logout.svg') }}"
                    alt=""
                    aria-hidden="true"
                >

                <span>
                    {{ 'navbar.logout'|trans }}
                </span>
            </a>

        {% else %}

            <a
                href="{{ path('app_login') }}"
                class="
                    navbar-admin-status
                    navbar-admin-status--disconnected
                "
                aria-label="{{ 'navbar.login_aria'|trans }}"
                title="{{ 'navbar.login'|trans }}"
            >
                <img
                    src="{{ asset('images/icones/login.svg') }}"
                    alt=""
                    aria-hidden="true"
                >

                <span>
                    {{ 'navbar.login'|trans }}
                </span>
            </a>

        {% endif %}

    </nav>

</header>