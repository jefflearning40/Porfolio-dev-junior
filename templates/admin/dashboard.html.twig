{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    Tableau de bord
{% endblock %}

{% block main %}

    <section class="admin-dashboard">

        <div class="admin-dashboard__header">
            <h1>
                Bienvenue dans l’administration
            </h1>

            <p>
                Gérez le contenu de votre portfolio depuis cet espace.
            </p>
        </div>

        <div class="admin-dashboard__grid">

            <article class="admin-dashboard__card">
                <h2>Projets</h2>

                <p>
                    Ajouter, modifier ou supprimer les projets du portfolio.
                </p>

                <span class="admin-dashboard__action">
                    Gestion bientôt disponible
                </span>
            </article>

            <article class="admin-dashboard__card">
                <h2>Compétences</h2>

                <p>
                    Gérer les technologies et compétences affichées sur le site.
                </p>

                <span class="admin-dashboard__action">
                    Gestion bientôt disponible
                </span>
            </article>

            <article class="admin-dashboard__card">
                <h2>Messages</h2>

                <p>
                    Consulter les messages envoyés depuis le formulaire de contact.
                </p>

                <span class="admin-dashboard__action">
                    Gestion bientôt disponible
                </span>
            </article>

            <article class="admin-dashboard__card">
                <h2>Portfolio</h2>

                <p>
                    Revenir rapidement sur la partie publique du site.
                </p>

                <a
                    href="{{ path('app_home', {
                        '_locale': 'fr'
                    }) }}"
                    class="btn btn-primary"
                >
                    Voir le portfolio
                </a>
            </article>

        </div>

    </section>

{% endblock %}