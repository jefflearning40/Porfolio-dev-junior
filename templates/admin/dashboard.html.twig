{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    Tableau de bord
{% endblock %}

{% block main %}

    <section class="admin-dashboard">

        <div class="admin-dashboard__header">

            <h1>
                Bienvenue dans l’administration
            </h1>

            <p>
                Gérez le contenu de votre portfolio depuis cet espace.
            </p>

        </div>

        <div class="admin-dashboard__grid">

            <article class="admin-dashboard__card">

                <h2>Projets</h2>

                <p>
                    <strong>{{ project_count }}</strong>
                    projet{% if project_count > 1 %}s{% endif %}
                    enregistré{% if project_count > 1 %}s{% endif %},
                    dont
                    <strong>{{ published_project_count }}</strong>
                    publié{% if published_project_count > 1 %}s{% endif %}.
                </p>

                <a
                    href="{{ projects_url }}"
                    class="btn btn-primary admin-dashboard__action"
                >
                    Gérer les projets
                </a>

            </article>

            <article class="admin-dashboard__card">

                <h2>Compétences</h2>

                <p>
                    <strong>{{ skill_count }}</strong>
                    compétence{% if skill_count > 1 %}s{% endif %}
                    disponible{% if skill_count > 1 %}s{% endif %}.
                </p>

                <a
                    href="{{ skills_url }}"
                    class="btn btn-primary admin-dashboard__action"
                >
                    Gérer les compétences
                </a>

            </article>

            <article class="admin-dashboard__card">

                <h2>Messages</h2>

                <p>
                    <strong>{{ message_count }}</strong>
                    message{% if message_count > 1 %}s{% endif %}
                    reçu{% if message_count > 1 %}s{% endif %}.
                </p>

                <a
                    href="{{ messages_url }}"
                    class="btn btn-primary admin-dashboard__action"
                >
                    Consulter les messages
                </a>

            </article>

            <article class="admin-dashboard__card">

                <h2>Portfolio</h2>

                <p>
                    Ouvrir la partie publique du portfolio.
                </p>

                <a
                    href="{{ path('app_home', {
                        '_locale': 'fr'
                    }) }}"
                    class="btn btn-primary admin-dashboard__action"
                >
                    Voir le portfolio
                </a>

            </article>

        </div>

    </section>

{% endblock %}