                                            title="JavaScript"
                                        >
                                    </li>

                                    <li>
                                        <img
                                            src="{{ asset('images/icones/css-3.svg') }}"
                                            alt="CSS"
                                            title="CSS"
                                        >
                                    </li>

                                </ul>

                                <div class="project-accordion-links">

                                    <a
                                        href="#"
