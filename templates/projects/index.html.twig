{% extends 'base.html.twig' %}

{% block title %}
    {{ 'projects.page_title'|trans }} | My Portfolio
{% endblock %}

{% block body %}

<section
    class="projects"
    aria-labelledby="projects-title"
    aria-describedby="projects-intro"
>

    <div class="projects-container">

        <header class="projects-header">

            <h1 id="projects-title">
                {{ 'projects.title'|trans }}
            </h1>

            <p id="projects-intro">
                {{ 'projects.intro'|trans }}
            </p>

        </header>

        <div
            class="accordion-group projects-accordion"
            aria-label="{{ 'projects.title'|trans }}"
        >

            {% set skill_icons = {
                'symfony': 'images/icones/symfony.svg',
                'php': 'images/icones/php-6.svg',
                'twig': 'images/icones/twig.svg',
                'javascript': 'images/icones/javascript.svg',
                'css': 'images/icones/css-3.svg',
                'css3': 'images/icones/css-3.svg',
                'html5': 'images/icones/html5.svg',
                'react': 'images/icones/react-native-1.svg',
                'tailwind css': 'images/icones/tailwind-css.svg',
                'doctrine orm': 'images/icones/doctrine-orm.png',
                'honeypot': 'images/icones/honeypot.png',
                'bootstrap': 'images/icones/bootstrap-5-1.svg',
                'docker': 'images/icones/docker-3.svg',
                'mysql': 'images/icones/mysql-3.svg',
                'gotenberg': 'images/icones/gotenberg.png',
                'mailpit': 'images/icones/mailpit.svg',
                'api rest': 'images/icones/rest-api-icon.svg'
            } %}

            {% for project in projects %}

                {% set project_id = 'project-' ~ project.id %}
                {% set normalized_status = project.status|lower|trim %}
                {% set is_in_progress = normalized_status == 'en cours' %}

                {% set status_translation_keys = {
                    'en cours': 'projects.status.in_progress',
                    'terminé': 'projects.status.completed',
                    'termine': 'projects.status.completed'
                } %}

                {% set status_translation_key =
                    status_translation_keys[normalized_status] ?? null
                %}

                <details
                    name="projects-accordion"
                    class="accordion project-accordion"
                    {% if loop.first %}open{% endif %}
                >

                    <summary
                        class="accordion-summary project-accordion-summary"
                        aria-describedby="{{ project_id }}-status"
                    >

                        <span class="project-accordion-title">
                            {{ project.title }}
                        </span>

                        <span
                            id="{{ project_id }}-status"
                            class="
                                project-accordion-status
                                {% if is_in_progress %}
                                    project-accordion-status--progress
                                {% endif %}
                            "
                        >
                            {% if status_translation_key %}
                                {{ status_translation_key|trans }}
                            {% else %}
                                {{ project.status }}
                            {% endif %}
                        </span>

                    </summary>

                    <div class="accordion-content project-accordion-content">

                        <div class="project-accordion-main">

                            <div class="project-accordion-info">

                                <p class="project-accordion-description">
                                    {{ project.description }}
                                </p>

                                <div class="project-accordion-footer">

                                    {% if project.skills is not empty %}

                                        <ul
                                            class="project-accordion-technologies"
                                            aria-label="Technologies utilisées pour {{ project.title }}"
                                        >

                                            {% for skill in project.skills %}

                                                {% set skill_key = skill.name|lower|trim %}
                                                {% set skill_icon = skill_icons[skill_key] ?? null %}

                                                <li>
                                                    {% if skill_icon %}

                                                        <img
                                                            src="{{ asset(skill_icon) }}"
                                                            alt="{{ skill.name }}"
                                                        >

                                                    {% else %}

                                                        <span>
                                                            {{ skill.name }}
                                                        </span>

                                                    {% endif %}
                                                </li>

                                            {% endfor %}

                                        </ul>

                                    {% endif %}

                                    <div
                                        class="project-accordion-links"
                                        aria-label="Liens du projet {{ project.title }}"
                                    >

                                        {% if project.githubUrl %}

                                            <a
                                                href="{{ project.githubUrl }}"
                                                class="project-link project-link--github"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label="{{ 'projects.links.github_aria'|trans({
                                                    '%project%': project.title
                                                }) }}"
                                            >

                                                <img
                                                    src="{{ asset('images/icones/github-icon-2.svg') }}"
                                                    alt=""
                                                    aria-hidden="true"
                                                >

                                                <span>
                                                    {{ 'projects.links.github'|trans }}
                                                </span>

                                            </a>

                                        {% endif %}

                                        {% if project.demoUrl %}

                                            <a
                                                href="{{ project.demoUrl }}"
                                                class="project-link project-link--website"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label="{{ 'projects.links.website_aria'|trans({
                                                    '%project%': project.title
                                                }) }}"
                                            >

                                                <img
                                                    src="{{ asset('images/icones/internet.svg') }}"
                                                    alt=""
                                                    aria-hidden="true"
                                                >

                                                <span>
                                                    {{ 'projects.links.website'|trans }}
                                                </span>

                                            </a>

                                        {% endif %}

                                    </div>

                                </div>

                            </div>

                            {% if project.image %}

                                <div
                                    class="
                                        project-accordion-logo
                                        {% if project.logoDarkBackground %}
                                            project-accordion-logo--black
                                        {% endif %}
                                    "
                                >

                                    <img
                                        src="{{ asset('uploads/projects/' ~ project.image) }}"
                                        alt="Logo du projet {{ project.title }}"
                                    >

                                </div>

                            {% endif %}

                        </div>

                    </div>

                </details>

            {% else %}

                <p>
                    Aucun projet n’est actuellement disponible.
                </p>

            {% endfor %}

        </div>

    </div>

</section>

{% endblock %}