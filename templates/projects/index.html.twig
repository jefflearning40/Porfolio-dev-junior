                <div class="project-accordion-content">

                    <div class="project-accordion-main">

                        <div class="project-accordion-info">

                            <p class="project-accordion-description">
                                Portfolio professionnel conçu pour présenter
                                mes compétences, mes projets, mon CV
                                et mon profil de développeur web.
                            </p>

                            <div class="project-accordion-footer">

                                <ul class="project-accordion-technologies">

                                    <li>
                                        <img
                                            src="{{ asset('images/icones/symfony.svg') }}"
