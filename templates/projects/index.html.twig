{% extends 'base.html.twig' %}

{% block title %}
    {{ 'projects.page_title'|trans }} | My Portfolio
{% endblock %}

{% block body %}

<section class="projects">

    <div class="projects-container">

        <header class="projects-header">

            <h1>{{ 'projects.title'|trans }}</h1>

            <p>
                {{ 'projects.intro'|trans }}
            </p>

        </header>

        <div class="projects-accordion">

            {% for project in projects %}

                <details
                    class="project-accordion"
                    {% if loop.first %}open{% endif %}
                >

                    <summary class="project-accordion-summary">

                        <span class="project-accordion-title">
                            {{ project.name_key|trans }}
                        </span>

                        <span class="
                            project-accordion-status
                            {% if project.in_progress %}
                                project-accordion-status--progress
                            {% endif %}
                        ">
                            {{ project.status_key|trans }}
                        </span>

                    </summary>

                    <div class="project-accordion-content">

                        <div class="project-accordion-main">

                            <div class="project-accordion-info">

                                <p class="project-accordion-description">
                                    {{ project.description_key|trans }}
                                </p>

                                <div class="project-accordion-footer">

                                    <ul class="project-accordion-technologies">

                                        {% for technology in project.technologies %}

                                            <li>

                                                <img
                                                    src="{{ asset(technology.icon) }}"
                                                    alt="{{ technology.name }}"
                                                    title="{{ technology.name }}"
                                                >

                                            </li>

                                        {% endfor %}

                                    </ul>

                                    <div class="project-accordion-links">

                                        <a
                                            href="{{ project.github_url }}"
                                            class="project-link project-link--github"
                                            aria-label="{{ 'projects.links.github_aria'|trans({'%project%': project.name_key|trans}) }}"
                                        >

                                            <img
                                                src="{{ asset('images/icones/github-icon-2.svg') }}"
                                                alt=""
                                                aria-hidden="true"
                                            >

                                            <span>
                                                {{ 'projects.links.github'|trans }}
                                            </span>

                                        </a>

                                        <a
                                            href="{{ project.website_url }}"
                                            class="project-link project-link--website"
                                            aria-label="{{ 'projects.links.website_aria'|trans({'%project%': project.name_key|trans}) }}"
                                        >

                                            <img
                                                src="{{ asset('images/icones/internet.svg') }}"
                                                alt=""
                                                aria-hidden="true"
                                            >

                                            <span>
                                                {{ 'projects.links.website'|trans }}
                                            </span>

                                        </a>

                                    </div>

                                </div>

                            </div>

                            <div class="
                                project-accordion-logo
                                {% if project.dark_logo_background %}
                                    project-accordion-logo--black
                                {% endif %}
                            ">

                                <img
                                    src="{{ asset(project.logo) }}"
                                    alt="{{ project.name_key|trans }}"
                                >

                            </div>

                        </div>

                    </div>

                </details>

            {% endfor %}

        </div>

    </div>

</section>

{% endblock %}